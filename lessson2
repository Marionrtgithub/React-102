            <p>isemployed: {setisEmployed ? "Yes" : "No"}</p>
            <button onClick={Marionzeee}>Onzee</button>
        </div>
    );

}
export default MyComponent;
import React,{useState} from "react";
function Onchange(){
    const [name, SetName] = useState("");
    const[quantity, setQuantity] = useState(1);
    const [comment, setComment] = useState("");
    const[payment, setPayment] = useState("");
    const[Shipping, setShipping] =useState("");
    function handleNameChange(event) { 
        SetName(event.target.value);
    }
    function handleQuantityChange(event){
        setQuantity(event.target.value);
    }
    function handleCommentChange(event){
        setComment(event.target.value);
    }
    function handlePaymentChange(event){
        setPayment(event.target.value);
    }
    function handleShippingChange(event){
        setShipping(event.target.value);
    }
    return(<div>
        <input value={name} onChange={handleNameChange} />
        <p>name: {name}</p>
        <input value={quantity} onChange={handleQuantityChange} type="number" />
        <p>quantity: {quantity}</p>
        <textarea value={comment} onChange={handleCommentChange} placeholder="Enter the delivery orders"/>
        <p>comment: {comment}</p>
        <select value={payment} onChange={handlePaymentChange}>
            <option value ="">Select an options</option>
            <option value ="Visa">Visa</option>
            <option value ="PayPal">PayPal</option>
            <option value ="Mastercard">MasterCard</option>
            <option value ="GiftCard">GiftCard</option>
        </select>
        <p>payment: {payment}</p>
        <label>
        <input  type="radio" value ="Pick up " 
                 checked={Shipping==="Pick up"} OnChange ={handleShippingChange}/>

             Pick up 
        </label><br/>
        <label>
        <input  type="radio" value ="Delivery"
                checked ={Shipping==="Delivery"} OnChange ={handleShippingChange}/>
            Delivery                 
        </label>
        <p>Shipping: {Shipping}</p>
    </div>)
}
export default Onchange;

function Profilepicture(){
    const imgurl = './src/assets/profile.jpg';
    const handleclick = (e) =>e.target.style.display = 'none';
    return(<img onClick={(e)=>handleclick(e)} width=" 20%" height="20%" src={imgurl}></img>)
}
export default Profilepicture;

body{
  background-color: rgba(165, 133, 196, 0.438);
  font-family: sans-serif Arial, Helvetica, sans-serif;
}

.Count-container{
  text-align: center;
  font-family: Arial, Helvetica, sans-serif;
}
.Count-people{
  font-size: 6rem;
  margin-bottom: 10px;
  margin-top: 0;
}
.Count-display{
  margin-top: 0;
  font-size: 5em;
  margin-bottom: 50px;
}
.Count-button{
  margin: 0px 10px;
  background-color: rgb(51, 51, 139);
  font-size: 50px;
  font-weight: bold;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  color: grey;
  
}
.Count-button:hover{
  background-color: rgb(184, 184, 197);
  transition: ease 0.2s;
}
.color-picker-container{
  display: flex;
  align-items: center;
  flex-direction: column;
}
h1{
  margin: 50px;
  font-size: 3rem;
}
.Color-display{
  width: 300px;
  height: 300px;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 1px solid hsl(0, 0%, 75%);
  border-radius: 25px;
  transition: 0.2 ease;
  margin-bottom: 25px ;
 
}
.Color-display p{
  color: grey;
  font-size: 3rem;
  text-align: center;
}
label{
  font-size: 1.5rem;
  font-weight: bold;
  margin-bottom: 10px;
}
input[type="Color"]{
  width: 75px;
  height: 50px;
  padding: 5px;
  border-radius: 10px;
  border: 1px solid hsl(0, 0%, 80%);
}
